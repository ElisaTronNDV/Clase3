SECRET_KEY=changeme-generate-a-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=24
# Si corrés en WSL y el repo vive en un disco de Windows (/mnt/c/...), usá una ruta
# absoluta fuera de /mnt/c (ej: sqlite:////home/tu_usuario/.local/share/dyp-lasercore/lasercore.db).
# SQLite sobre /mnt/c puede tirar "disk I/O error" por el locking de archivos de WSL.
DATABASE_URL=sqlite:///./lasercore.db
CORS_ORIGINS=http://localhost:4200
